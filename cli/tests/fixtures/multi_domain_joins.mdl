domain customer {
  owner: "customer-platform"

  entity Customer @ 1 (additive) {
    @key
    customerId: uuid
    legalName: string
  }
}

domain orders {
  owner: "orders-platform"

  entity Order @ 1 (additive) {
    @key
    orderId: uuid
    customerId: uuid
    totalAmount: decimal(18,2)
    createdAt: timestamp
  }
}

domain payments {
  owner: "payments-platform"

  entity Payment @ 1 (additive) {
    @key
    paymentId: uuid
    orderId: uuid
    customerId: uuid
    amount: decimal(18,2)
    method: enum(card, ach, wire)
  }
}

domain analytics {
  owner: "analytics-platform"

  // Three-way join: customer (1) -> orders (1:N) -> payments (1:N),
  // joined on the composite (orderId, customerId) relationship.
  projection CustomerOrderPayment @ 1
    from orders.Order @ 1 as o
    join customer.Customer @ 1 as c on o.customerId == c.customerId
    join payments.Payment @ 1 as p on o.orderId == p.orderId
  {
    orderId <- o.orderId
    customerId <- o.customerId
    customerName <- c.legalName
    paymentId <- p.paymentId
    paymentMethod <- p.method
    orderTotal <- o.totalAmount
    paymentAmount <- p.amount
    isFullyPaid = p.amount == o.totalAmount
  }
}

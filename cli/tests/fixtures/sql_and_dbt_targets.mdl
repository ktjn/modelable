domain customer {
  owner: "customer-platform"

  entity Customer @ 1 (additive) {
    @key
    customerId: uuid
    legalName: string
    @pii
    email: string
    status: enum(active, suspended, deleted)
    creditLimit?: decimal(18,2)
    isVerified: bool
    createdAt: timestamp
  }
}

domain orders {
  owner: "orders-platform"

  entity Order @ 1 (additive) {
    @key
    orderId: uuid
    customerId: uuid
    totalAmount: decimal(18,2)
    lineItemCount: int
    createdAt: timestamp
  }

  // Computed field exercises SQL/dbt emission of derived columns; the
  // cross-domain ref exercises dbt `ref()`-style source mapping.
  projection OrderWithCustomer @ 1
    from orders.Order @ 1 as o
    join customer.Customer @ 1 as c on o.customerId == c.customerId
  {
    orderId <- o.orderId
    customerId <- o.customerId
    customerName <- c.legalName
    totalAmount <- o.totalAmount
    isHighValue = o.totalAmount > 1000.00
  }
}

domain customer {
  owner: "customer-platform"

  entity Customer @ 1 (additive) {
    @key
    customerId: uuid
    legalName: string
    @pii
    email: string
    createdAt: timestamp
  }
}

domain orders {
  owner: "orders-platform"

  entity Order @ 1 (additive) {
    @key
    orderId: uuid
    customerId: uuid
    @classification("confidential")
    totalAmount: decimal(18,2)
    createdAt: timestamp
  }
}

domain analytics {
  owner: "analytics-platform"

  // Cross-domain projection used to verify lineage/classification
  // propagation is consistent across OpenMetadata, OpenLineage, and ODCS
  // export targets.
  projection CustomerOrderSummary @ 1
    from orders.Order @ 1 as o
    join customer.Customer @ 1 as c on o.customerId == c.customerId
  {
    orderId <- o.orderId
    customerId <- o.customerId
    customerName <- c.legalName
    @pii
    customerEmail <- c.email
    @classification("confidential")
    orderTotal <- o.totalAmount
  }
}

{
  "name": "modelable-vscode",
  "displayName": "Modelable",
  "description": "VS Code support for Modelable .mdl files backed by the repo-local Python language server.",
  "version": "0.0.1",
  "private": true,
  "publisher": "modelable",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:mdl"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mdl",
        "aliases": [
          "Modelable",
          "MDL"
        ],
        "extensions": [
          ".mdl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configurationDefaults": {
      "[mdl]": {
        "editor.semanticHighlighting.enabled": true
      }
    },
    "grammars": [
      {
        "language": "mdl",
        "scopeName": "source.mdl",
        "path": "./syntaxes/modelable.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "overrides": {
    "mocha": {
      "diff": "^9.0.0",
      "serialize-javascript": "^7.0.5"
    }
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.4.1",
    "mocha": "^11.7.6",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "check": "node --check extension.js",
    "build": "tsc -p tsconfig.json",
    "test": "node ./out/test/runTests.js"
  }
}

{
  "name": "modelable-vscode",
  "displayName": "Modelable",
  "description": "Language support for Modelable .mdl data contracts.",
  "version": "1.2.1",
  "private": false,
  "publisher": "modelable",
  "license": "Apache-2.0",
  "homepage": "https://github.com/ktjn/modelable",
  "bugs": {
    "url": "https://github.com/ktjn/modelable/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ktjn/modelable.git",
    "directory": "vscode"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:mdl"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mdl",
        "aliases": [
          "Modelable",
          "MDL"
        ],
        "extensions": [
          ".mdl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configurationDefaults": {
      "[mdl]": {
        "editor.semanticHighlighting.enabled": true
      }
    },
    "configuration": {
      "title": "Modelable",
      "properties": {
        "modelable.pythonPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to a Python interpreter that has the `modelable` package installed. The extension launches it as `<pythonPath> -m modelable.lsp`. Leave empty to auto-detect (repo-local `cli/.venv` during Modelable development, otherwise `modelable` on PATH)."
        },
        "modelable.serverCommand": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Full command and arguments used to launch the Modelable language server, e.g. `[\"modelable\", \"lsp\"]`. Overrides `modelable.pythonPath` and auto-detection when set."
        }
      }
    },
    "grammars": [
      {
        "language": "mdl",
        "scopeName": "source.mdl",
        "path": "./syntaxes/modelable.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^10.1.0"
  },
  "overrides": {
    "mocha": {
      "diff": "^9.0.0",
      "serialize-javascript": "^7.0.5"
    }
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "mocha": "^11.7.6",
    "typescript": "^7.0.2"
  },
  "scripts": {
    "check": "node --check extension.js",
    "build": "tsc -p tsconfig.json",
    "test": "node ./out/test/runTests.js",
    "package": "vsce package"
  }
}

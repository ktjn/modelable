// Scenario 08 — Distributed multi-registry with cross-team lineage
//
// Three independent teams each own a registry node (git repository):
//
//   customer-platform-registry  →  owns: customer
//   orders-registry             →  owns: orders, shipping
//   analytics-registry          →  owns: analytics
//
// The analytics team imports from both upstream repos. The topology is a DAG:
//
//   customer-platform-registry
//         ↓
//   orders-registry          (orders domain refs customer.Customer)
//         ↓
//   analytics-registry       (projects across customer + orders)
//
// On every `modelable compile` the CLI:
//   1. Builds the graph from this file and import declarations
//   2. Topologically sorts the dependency order
//   3. git-fetches each peer in order (customer first, then orders)
//   4. Verifies content signatures on pinned imports
//   5. Compiles projections against the mirrored models
//   6. Appends CrossRegistryRef events to lineage-log/
//   7. Writes consumers/ entries back to each peer repo
//
// No running server is required.

workspace "analytics-platform" {
  description: "Analytics registry — projects across customer and orders without owning either source domain."

  registry {
    id:   "analytics-registry"
    owns: ["analytics"]
  }

  peers: [
    {
      id:        "customer-platform-registry"
      git:       "git@github.com:acme/customer-models.git"
      branch:    "main"
      sync:      eager
      writeback: pr
    },
    {
      id:        "orders-registry"
      git:       "git@github.com:acme/orders-models.git"
      branch:    "main"
      sync:      eager
      writeback: commit
    }
  ]

  generate {
    docs          -> "./generated/docs/"
    typescript    -> "./generated/types/"
    jsonschema    -> "./generated/jsonschema/"
    sql(postgres) -> "./generated/sql/"
  }
}

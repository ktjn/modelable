domain cpq {
  owner: "pricing-team"
  contact: "pricing@example.com"
  description: "Pricing master: tiered price lists, promotional discount rules, and approval workflows. Consumed at checkout (order pricing), in analytics (margin and discount effectiveness), and by CRM (tier assignment drives customer segmentation)."

  entity PriceTier @ 1 (additive) {
    @key             priceTierId:          uuid
                     tierCode:             string    // e.g. "standard", "partner", "vip", "reseller"
                     tierName:             string
                     description?:         string
                     baseDiscountBps:      int = 0   // basis-points off list price; 1000 = 10 %
                     requiresApproval:     bool
                     isActive:             bool
                     createdAt:            timestamp
  }

  entity PriceListEntry @ 2 (additive) {
    @key             entryId:              uuid
                     priceTierId:          ref<cpq.PriceTier>
                     productId:            ref<pim.Product>
                     variantId?:           ref<pim.ProductVariant>
                     currencyCode:         string    // format: iso4217
                     unitPriceCents:       int       // tier sell price
                     listPriceCents:       int       // undiscounted catalogue price
                     minQuantity:          int = 1
                     effectiveFrom:        date
                     effectiveTo?:         date
                     isActive:             bool
                     lastReviewedByUserId: ref<iam.InternalUser>
                     updatedAt:            timestamp
  }

  entity DiscountRule @ 1 (additive) {
    @key             ruleId:               uuid
                     priceTierId?:         ref<cpq.PriceTier>    // null applies to all tiers
                     productId?:           ref<pim.Product>       // null applies to all products
                     discountBps:          int
                     minOrderValueCents?:  int
                     minQuantity?:         int
                     stackable:            bool = false  // whether it combines with tier discount
                     startAt:              timestamp
                     endAt?:               timestamp
                     approvedByUserId:     ref<iam.InternalUser>
                     isActive:             bool
                     createdAt:            timestamp
  }

  event PriceListEntryChanged @ 1 {
    @key             eventId:              uuid
                     entryId:              ref<cpq.PriceListEntry>
                     productId:            ref<pim.Product>
                     priceTierId:          ref<cpq.PriceTier>
                     currencyCode:         string
                     previousUnitPriceCents: int
                     newUnitPriceCents:    int
                     changedByUserId:      ref<iam.InternalUser>
                     occurredAt:           timestamp
  }

  event DiscountRuleActivated @ 1 {
    @key             eventId:              uuid
                     ruleId:               ref<cpq.DiscountRule>
                     approvedByUserId:     ref<iam.InternalUser>
                     occurredAt:           timestamp
  }
}
